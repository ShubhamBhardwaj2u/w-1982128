        ],
        "measures": [
          {
            "name": "Total Market Value",
            "expression": "SUM(Fact_Position[MarketValue])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\"/></Format>"
              }
            ]
          },
          {
            "name": "Total Market Quantity",
            "expression": "SUM(Fact_Position[MarketQuantity])",
            "formatString": "#,0.00;(#,0.00);#,0.00"
          },
          {
            "name": "Average Market Price",
            "expression": "AVERAGE(Fact_Position[MarketPrice])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\"/></Format>"
              }
            ]
          },
          {
            "name": "Position Count",
            "expression": "COUNTROWS(Fact_Position)",
            "formatString": "#,0;(#,0);#,0"
          },
          {
            "name": "Total Original Face Value",
            "expression": "SUM(Fact_Position[OriginalFaceValue])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\"/></Format>"
              }
            ]
          }
        ],
