          },
          {
            "name": "MarketValueByAccount",
            "dataType": "decimal",
            "expression": "CALCULATE(SUM(Fact_Position[MarketValue]),FILTER(Fact_Position,EARLIER(Fact_Position[AccountNumber],1) && Fact_Position[PositionDateKey] && EARLIER(Fact_Position[PositionDateKey],1) && Fact_Position[BusinessUnitKey] && EARLIER(Fact_Position[BusinessUnitKey],1)))",
